{
  "manifest_version": 3,
  "name": "TurboChat for All AI",
  "version": "2.3.0",
  "description": "Speed fix + full export (PDF, Word, JSON, Markdown) for ChatGPT, Claude & Gemini.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "activeTab",
    "sidePanel",
    "windows"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://*.googleusercontent.com/*",
    "https://*.google.com/*",
    "https://oaidalleapiprodscus.blob.core.windows.net/*",
    "https://*.openai.com/*",
    "https://turbochat.zhuanyeonglim.workers.dev/*",
    "https://www.perplexity.ai/*",
    "https://poe.com/*",
    "https://files.anthropic.com/*",
    "https://*.anthropic.com/*",
    "https://claude-files.s3.amazonaws.com/*",
    "https://*.s3.amazonaws.com/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://turbochat.zhuanyeonglim.workers.dev/*"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "page_bootstrap.js"
      ],
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "inject.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://www.perplexity.ai/*",
        "https://poe.com/*"
      ],
      "js": [
        "export_core.js",
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "claude_inject.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "export_core.js",
        "claude_content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "gemini_inject.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "export_core.js",
        "gemini_content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://turbochat.zhuanyeonglim.workers.dev/*"
      ],
      "js": [
        "success_bridge.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "worker.js",
        "prompts.html",
        "prompts.js"
      ],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "load-more": {
      "suggested_key": {
        "default": "Alt+Shift+L",
        "mac": "Alt+Shift+L"
      },
      "description": "Load previous messages"
    },
    "open-prompts": {
      "suggested_key": {
        "default": "Alt+Shift+P",
        "mac": "Alt+Shift+P"
      },
      "description": "Open Prompt Library"
    }
  },
  "side_panel": {
    "default_path": "prompts.html"
  }
}